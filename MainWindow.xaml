<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Security Awareness Platform"
        Height="840" Width="1200"
        MinHeight="640" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgApp}"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62"/>   <!-- title bar -->
            <RowDefinition Height="46"/>   <!-- nav bar -->
            <RowDefinition Height="*"/>    <!-- content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             TITLE BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#090D1A">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,1">
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="#00D4FF" Offset="0.5"/>
                    <GradientStop Color="#050810" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>0,0,0,1</Border.BorderThickness>

            <Grid Margin="24,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo mark + wordmark -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Shield with glow -->
                    <Border Width="34" Height="34" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#7C3AED" BlurRadius="18"
                                              ShadowDepth="0" Opacity="0.8"/>
                        </Border.Effect>
                        <Viewbox Width="34" Height="34">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12 2L4 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-3z">
                                    <Path.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#00D4FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Path.Fill>
                                </Path>
                                <Path Fill="White" Opacity="0.95"
                                      Data="M10 17l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="CYBER" FontFamily="Consolas"
                                       FontSize="18" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                        <GradientStop Color="#9D62FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="BOT" FontFamily="Consolas"
                                       FontSize="18" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00D4FF" Offset="0"/>
                                        <GradientStop Color="#00E5A0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="Security Awareness Platform"
                                   FontFamily="Segoe UI" FontSize="9.5"
                                   Foreground="#2D3D60"/>
                    </StackPanel>
                </StackPanel>

                <!-- Centre status pill -->
                <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        CornerRadius="20" Padding="16,6" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#00E5A0" Opacity="0.05"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#00E5A0" Opacity="0.2"/>
                    </Border.BorderBrush>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#00E5A0"/>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00E5A0" BlurRadius="8"
                                                  ShadowDepth="0" Opacity="1"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock x:Name="StatusLabel"
                                   Text="ONLINE  ·  Ready to assist"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#00E5A0"/>
                    </StackPanel>
                </Border>

                <!-- User badge -->
                <Border Grid.Column="2" VerticalAlignment="Center"
                        Background="#0D1220" BorderBrush="#1A2540"
                        BorderThickness="1" CornerRadius="20" Padding="14,7">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#7A8BB0"
                                      Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="UserInfoLabel" Text="Not identified"
                                   FontFamily="Segoe UI" FontSize="11.5"
                                   Foreground="#7A8BB0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             NAV BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#090D1A"
                BorderBrush="#111928" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tabs -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Stretch">

                    <RadioButton x:Name="TabChat" Style="{StaticResource NavTab}"
                                 IsChecked="True" Checked="Tab_Checked" Tag="Chat">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,7,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#7A8BB0"
                                          Data="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Chat" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="TabTasks" Style="{StaticResource NavTab}"
                                 Checked="Tab_Checked" Tag="Tasks">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,7,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#7A8BB0"
                                          Data="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Tasks" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="TabQuiz" Style="{StaticResource NavTab}"
                                 Checked="Tab_Checked" Tag="Quiz">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,7,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#7A8BB0"
                                          Data="M11.5 2C6.81 2 3 5.81 3 10.5S6.81 19 11.5 19h.5v3c4.86-2.34 8-7 8-11.5C20 5.81 16.19 2 11.5 2zm1 14.5h-2v-2h2v2zm0-4h-2c0-3.25 3-3 3-5 0-1.1-.9-2-2-2s-2 .9-2 2h-2c0-2.21 1.79-4 4-4s4 1.79 4 4c0 2.5-3 2.75-3 5z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Quiz" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="TabLog" Style="{StaticResource NavTab}"
                                 Checked="Tab_Checked" Tag="Log">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,7,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#7A8BB0"
                                          Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Activity Log" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                </StackPanel>

                <!-- Toolbar right -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button x:Name="BtnVoice" Style="{StaticResource BtnGhost}"
                            Padding="12,6" Margin="4,0" Click="VoiceButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#7A8BB0"
                                          Data="M12 15c1.66 0 3-1.34 3-3V6c0-1.66-1.34-3-3-3S9 4.34 9 6v6c0 1.66 1.34 3 3 3zm-1-9c0-.55.45-1 1-1s1 .45 1 1v6c0 .55-.45 1-1 1s-1-.45-1-1V6zm6 6c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-2.08c3.39-.49 6-3.39 6-6.92h-2z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Voice" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnTip" Style="{StaticResource BtnGhost}"
                            Padding="12,6" Margin="4,0" Click="TipsButton_Click">
                        <TextBlock Text="Random Tip"/>
                    </Button>
                    <Button x:Name="BtnClear" Style="{StaticResource BtnDanger}"
                            Padding="12,6" Margin="4,0" Click="ClearButton_Click">
                        <TextBlock Text="Clear Chat"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             BODY
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR ──────────────────────────────────────── -->
            <Border Grid.Column="0" BorderBrush="#1A2540" BorderThickness="0,0,1,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#090D1A" Offset="0"/>
                        <GradientStop Color="#0A0F1C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14,20,14,20">

                        <!-- ASCII art card -->
                        <Border CornerRadius="10" Padding="8,7" Margin="0,0,0,18"
                                BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="#7C3AED" Opacity="0.06"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#7C3AED" Opacity="0.2"/>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C3AED" BlurRadius="20"
                                                  ShadowDepth="0" Opacity="0.15"/>
                            </Border.Effect>
                            <TextBlock x:Name="AsciiArtBlock"
                                       FontFamily="Consolas" FontSize="5.5"
                                       TextWrapping="NoWrap"
                                       LineStackingStrategy="BlockLineHeight" LineHeight="9">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                        <GradientStop Color="#00D4FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Border>

                        <!-- Section label -->
                        <TextBlock Text="TOPICS" FontFamily="Consolas" FontSize="8.5"
                                   Foreground="#2D3D60" Margin="4,0,0,8"/>

                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="passwords" Click="TopicBtn_Click" Content="passwords"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="phishing" Click="TopicBtn_Click" Content="phishing"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="scams" Click="TopicBtn_Click" Content="scams"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="malware" Click="TopicBtn_Click" Content="malware"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="privacy" Click="TopicBtn_Click" Content="privacy"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="vpn" Click="TopicBtn_Click" Content="vpn"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="2fa" Click="TopicBtn_Click" Content="2fa"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="software updates" Click="TopicBtn_Click" Content="software updates"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Tag="social engineering" Click="TopicBtn_Click" Content="social engineering"/>

                        <!-- Gradient divider -->
                        <Border Height="1" Margin="0,14,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#050810" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="PART 3" FontFamily="Consolas" FontSize="8.5"
                                   Foreground="#2D3D60" Margin="4,0,0,8"/>

                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Content="Add Task" Click="QuickAddTask_Click"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Content="View Tasks" Click="QuickViewTasks_Click"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Content="Start Quiz" Click="QuickStartQuiz_Click"/>
                        <Button Style="{StaticResource BtnTopic}" Height="32" Margin="0,0,0,2"
                                Content="Activity Log" Click="QuickLog_Click"/>

                        <!-- Gradient divider -->
                        <Border Height="1" Margin="0,14,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                    <GradientStop Color="#050810" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="SHORTCUTS" FontFamily="Consolas" FontSize="8.5"
                                   Foreground="#2D3D60" Margin="4,0,0,8"/>
                        <TextBlock Text="help  →  all features"    FontFamily="Consolas" FontSize="9.5" Foreground="#1A2540" Margin="4,0,0,4"/>
                        <TextBlock Text="quiz  →  start test"      FontFamily="Consolas" FontSize="9.5" Foreground="#1A2540" Margin="4,0,0,4"/>
                        <TextBlock Text="show tasks  →  task list" FontFamily="Consolas" FontSize="9.5" Foreground="#1A2540" Margin="4,0,0,4"/>
                        <TextBlock Text="show log  →  activity"    FontFamily="Consolas" FontSize="9.5" Foreground="#1A2540" Margin="4,0,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── MAIN PANELS ───────────────────────────────────── -->
            <Grid Grid.Column="1">

                <!-- ─── CHAT PANEL ──────────────────────────────── -->
                <Grid x:Name="PanelChat" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,6">
                        <ScrollViewer.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#080C18" Offset="0"/>
                                <GradientStop Color="#050810" Offset="1"/>
                            </LinearGradientBrush>
                        </ScrollViewer.Background>
                        <StackPanel x:Name="ChatPanel" Margin="24,10,24,10"/>
                    </ScrollViewer>

                    <!-- Input bar -->
                    <Border Grid.Row="1" Padding="20,12">
                        <Border.Background>
                            <SolidColorBrush Color="#090D1A"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#7C3AED" Offset="0"/>
                                <GradientStop Color="#00D4FF" Offset="0.5"/>
                                <GradientStop Color="#050810" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>0,1,0,0</Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputTextBox" Grid.Column="0"
                                     Style="{StaticResource ChatInput}" Height="48"
                                     VerticalContentAlignment="Center"
                                     KeyDown="InputTextBox_KeyDown"
                                     GotFocus="InputTextBox_GotFocus"
                                     LostFocus="InputTextBox_LostFocus"/>
                            <Button x:Name="SendButton" Grid.Column="2"
                                    Style="{StaticResource BtnPrimary}"
                                    Padding="24,0" Height="48" MinWidth="108"
                                    Click="SendButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,7,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="White" Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Send" VerticalAlignment="Center"
                                               FontSize="13.5" FontFamily="Segoe UI Semibold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Hint bar -->
                    <Border Grid.Row="2" Background="#050810" Padding="20,6">
                        <TextBlock Text="Enter to send  ·  Type 'help' to see all commands  ·  Type 'quiz' to start a knowledge test"
                                   FontFamily="Consolas" FontSize="10"
                                   Foreground="#1A2540"/>
                    </Border>
                </Grid>

                <!-- ─── TASKS PANEL ──────────────────────────────── -->
                <Grid x:Name="PanelTasks" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#090D1A"
                            BorderBrush="#1A2540" BorderThickness="0,0,0,1" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Task Manager" FontFamily="Segoe UI Semibold"
                                           FontSize="20" Foreground="#F0F4FF"/>
                                <TextBlock Text="Track and manage your cybersecurity tasks"
                                           FontFamily="Segoe UI" FontSize="11.5"
                                           Foreground="#2D3D60" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource BtnPrimary}"
                                    Padding="18,9" Click="AddTaskDialog_Click">
                                <TextBlock Text="+ New Task" FontSize="13"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Padding="24,14">
                        <ScrollViewer.Background>
                            <SolidColorBrush Color="#050810"/>
                        </ScrollViewer.Background>
                        <StackPanel x:Name="TaskListPanel">
                            <TextBlock Text="Use the input below or type in Chat to add tasks."
                                       FontFamily="Segoe UI" FontSize="13"
                                       Foreground="#2D3D60"
                                       HorizontalAlignment="Center"
                                       Margin="0,50,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#090D1A"
                            BorderBrush="#1A2540" BorderThickness="0,1,0,0" Padding="24,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TaskInputBox" Grid.Column="0"
                                     Style="{StaticResource ChatInput}" Height="44"
                                     VerticalContentAlignment="Center"
                                     GotFocus="TaskInputBox_GotFocus"
                                     LostFocus="TaskInputBox_LostFocus"/>
                            <Button Grid.Column="2" Style="{StaticResource BtnPrimary}"
                                    Padding="20,0" Height="44" Click="SendTaskCommand_Click">
                                <TextBlock Text="Add Task" FontSize="13"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ─── QUIZ PANEL ───────────────────────────────── -->
                <Grid x:Name="PanelQuiz" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#090D1A"
                            BorderBrush="#1A2540" BorderThickness="0,0,0,1" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Cybersecurity Quiz" FontFamily="Segoe UI Semibold"
                                           FontSize="20" Foreground="#F0F4FF"/>
                                <TextBlock Text="10 randomised questions — multiple choice and true/false"
                                           FontFamily="Segoe UI" FontSize="11.5"
                                           Foreground="#2D3D60" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource BtnPrimary}"
                                    Padding="18,9" Click="StartQuizFromPanel_Click">
                                <TextBlock Text="Start Quiz" FontSize="13"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1">
                        <Border.Background>
                            <SolidColorBrush Color="#050810"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Width="56" Height="56" Margin="0,0,0,16">
                                <Canvas Width="24" Height="24">
                                    <Path Opacity="0.2"
                                          Data="M11.5 2C6.81 2 3 5.81 3 10.5S6.81 19 11.5 19h.5v3c4.86-2.34 8-7 8-11.5C20 5.81 16.19 2 11.5 2zm1 14.5h-2v-2h2v2zm0-4h-2c0-3.25 3-3 3-5 0-1.1-.9-2-2-2s-2 .9-2 2h-2c0-2.21 1.79-4 4-4s4 1.79 4 4c0 2.5-3 2.75-3 5z">
                                        <Path.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C3AED" Offset="0"/>
                                                <GradientStop Color="#00D4FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Fill>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Ready to test your skills?"
                                       FontFamily="Segoe UI Semibold" FontSize="16"
                                       Foreground="#2D3D60" HorizontalAlignment="Center"/>
                            <TextBlock Text="Click Start Quiz or type 'quiz' in the Chat tab."
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#1A2540" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ─── LOG PANEL ────────────────────────────────── -->
                <Grid x:Name="PanelLog" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#090D1A"
                            BorderBrush="#1A2540" BorderThickness="0,0,0,1" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Activity Log" FontFamily="Segoe UI Semibold"
                                           FontSize="20" Foreground="#F0F4FF"/>
                                <TextBlock Text="Timestamped record of all actions this session"
                                           FontFamily="Segoe UI" FontSize="11.5"
                                           Foreground="#2D3D60" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource BtnGhost}"
                                    Padding="16,8" Click="RefreshLog_Click">
                                <TextBlock Text="Refresh"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Padding="24,16">
                        <ScrollViewer.Background>
                            <SolidColorBrush Color="#050810"/>
                        </ScrollViewer.Background>
                        <TextBlock x:Name="LogTextBlock"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="#2D3D60"
                                   TextWrapping="Wrap" LineHeight="24"/>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
