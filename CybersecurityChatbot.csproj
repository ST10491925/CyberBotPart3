<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>CybersecurityChatbot</AssemblyName>
    <RootNamespace>CybersecurityChatbot</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="Audio\greeting.wav" Condition="Exists('Audio\greeting.wav')" />
  </ItemGroup>
</Project>
